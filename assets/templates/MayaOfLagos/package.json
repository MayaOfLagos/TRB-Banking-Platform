{
    "name": "mayaoflagos-theme",
    "version": "1.0.0",
    "description": "Tailwind CSS setup for MayaOfLagos banking template",
    "main": "index.js",
    "scripts": {
        "build-css": "tailwindcss -i ./css/tailwind-simple.css -o ./css/tailwind-compiled.css --watch",
        "build": "tailwindcss -i ./css/tailwind-simple.css -o ./css/tailwind-compiled.css --minify"
    },
    "devDependencies": {
        "tailwindcss": "^3.3.0",
        "@tailwindcss/forms": "^0.5.6",
        "@tailwindcss/typography": "^0.5.10"
    }
}